{
  "name": "jackdaw sandbox",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:America/Detroit}"
    }
  },
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--add-host=host.docker.internal:host-gateway"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "ms-python.python",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "telemetry.telemetryLevel": "off",
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "/bin/zsh"
          }
        },
        "files.associations": {
          "**/playbooks/*.yml": "ansible",
          "**/playbooks/*.yaml": "ansible",
          "**/roles/**/*.yml": "ansible",
          "**/roles/**/*.yaml": "ansible"
        },
        "ansible.python.interpreterPath": "/usr/bin/python3",
        "ansible.validation.lint.enabled": true,
        "ansible.validation.lint.path": "ansible-lint"
      }
    }
  },
  "remoteUser": "node",
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "mounts": [
    "source=claude-code-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=claude-code-config-${devcontainerId},target=/home/node/.claude,type=volume",
    "source=claude-code-ansible-${devcontainerId},target=/home/node/.ansible,type=volume"
  ],
  "remoteEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "CLAUDE_CONFIG_DIR": "/home/node/.claude",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "true",
    "ANSIBLE_HOST_KEY_CHECKING": "False"
  },
  "postCreateCommand": "sudo /usr/local/bin/firewall.sh init",
  "postStartCommand": "sudo /usr/local/bin/firewall.sh init",
  "waitFor": "postCreateCommand"
}
