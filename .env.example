# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# DNS provider to use for DNS-01 challenges.  Supported: porkbun, cloudflare, route53, namecheap, null
DNS_PROVIDER=porkbun

# Public hostname of this relay (bare domain for production; full URL for local dev).
# Production example:  RELAY_DOMAIN=jackdaw.example.com
# Local dev example:   RELAY_DOMAIN=http://host.docker.internal:8000
RELAY_DOMAIN=jackdaw.example.com

# Email address registered with Let's Encrypt.
ACME_EMAIL=admin@example.com

# ---------------------------------------------------------------------------
# DNS provider credentials (supply the block for your chosen DNS_PROVIDER)
# ---------------------------------------------------------------------------

# Porkbun
PORKBUN_API_KEY=pk1_...
PORKBUN_SECRET_API_KEY=sk1_...

# Cloudflare
# CLOUDFLARE_API_TOKEN=...

# Amazon Route 53 (standard AWS credential env vars)
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...   # optional — for temporary credentials (IAM roles, etc.)

# Namecheap (NAMECHEAP_CLIENT_IP must be whitelisted in Namecheap API settings)
# NAMECHEAP_API_USER=...
# NAMECHEAP_API_KEY=...
# NAMECHEAP_USERNAME=...  # optional — defaults to NAMECHEAP_API_USER
# NAMECHEAP_CLIENT_IP=...

# ---------------------------------------------------------------------------
# Optional — defaults shown
# ---------------------------------------------------------------------------

# Released image tag to run from ghcr.io/tholent/jackdaw (used by docker-compose).
# Pin a specific release for deployments, e.g. JACKDAW_VERSION=0.1.0
# JACKDAW_VERSION=latest

# Let's Encrypt directory URL.
# Staging: https://acme-staging-v02.api.letsencrypt.org/directory
# Production (default): https://acme-v02.api.letsencrypt.org/directory
# LE_DIRECTORY=https://acme-v02.api.letsencrypt.org/directory

# Seconds to wait after setting a DNS TXT record before notifying LE.
# DNS_PROPAGATION_WAIT=30

# Comma-separated list of base domains this relay will issue certs for.
# Empty means only HTTP-01 proof governs access (self-service).
# Set to restrict issuance further, e.g. to a single internal zone.
# ALLOWED_DOMAINS=example.com,example.org

# Log level: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# SQLite database path.  Must be on a persistent volume in Docker.
# DATABASE_URL=sqlite+aiosqlite:////data/relay.db

# Path to the persisted Let's Encrypt account private key.
# LE_ACCOUNT_KEY_PATH=/data/le_account.key

# Directory where fullchain.pem and privkey.pem are written.
# SSL_DIR=/data/ssl

# Nonce TTL in seconds.
# NONCE_TTL=600

# Set to false only when using a test CA with a self-signed TLS cert (e.g. Pebble).
# LE_VERIFY_SSL=true

# Terminate TLS in the app on port 443 (the production default).  Set to false
# to serve plain HTTP on port 8000 instead — for integration tests or when an
# external proxy terminates TLS.
# SERVE_TLS=true

# ---------------------------------------------------------------------------
# HTTP-01 challenge validation (relay → client)
# ---------------------------------------------------------------------------

# TCP port the relay contacts on the client host to fetch the challenge token.
# CHALLENGE_HTTP_PORT=80

# Seconds before an HTTP-01 fetch attempt times out.
# CHALLENGE_TIMEOUT=5

# Number of fetch attempts before marking the challenge invalid.
# CHALLENGE_RETRIES=3

# Seconds to wait between retry attempts.
# CHALLENGE_RETRY_DELAY=2

# ---------------------------------------------------------------------------
# Advanced (optional)
# ---------------------------------------------------------------------------

# Comma-separated apex (registrable) zones.  Only needed for multi-label public
# suffixes where the default last-two-labels heuristic is wrong, e.g. set
# example.co.uk so _acme-challenge is written to the right zone.
# DNS_ZONE_OVERRIDES=example.co.uk

# Per-account order rate limit.  0 (default) disables it.  A positive value caps
# new orders per account within ORDER_RATE_WINDOW seconds, protecting against
# exhausting Let's Encrypt's rate limits (~50 certs/registered domain/week).
# ORDER_RATE_LIMIT=0
# ORDER_RATE_WINDOW=604800
